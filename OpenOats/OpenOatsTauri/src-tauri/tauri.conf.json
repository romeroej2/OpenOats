{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpenOats",
  "version": "0.1.0",
  "identifier": "com.openoats.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenOats",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "contentProtected": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "macOS": {
      "entitlements": "OpenOats.entitlements",
      "minimumSystemVersion": "13.0",
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
